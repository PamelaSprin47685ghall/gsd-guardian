{
  "name": "gsd-guardian",
  "version": "5.1.0",
  "description": "Auto-mode recovery extension for GSD: retries recoverable failures without losing session context.",
  "type": "module",
  "exports": "./index.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "prepare": "husky"
  },
  "keywords": [
    "pi-package",
    "gsd-extension",
    "auto-mode",
    "recovery"
  ],
  "gsd": {
    "extension": true
  },
  "pi": {
    "extensions": [
      "./index.js"
    ]
  },
  "lint-staged": {
    "**/*.{js,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
