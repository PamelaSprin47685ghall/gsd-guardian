{
  "id": "guardian",
  "name": "Guardian",
  "version": "5.1.0",
  "description": "Recovers selected auto-mode failures with context-preserving retries and repair handoff.",
  "tier": "community",
  "requires": {
    "platform": ">=2.29.0"
